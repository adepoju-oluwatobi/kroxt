{
  "name": "kroxt",
  "version": "1.1.5",
  "keywords": [
    "auth",
    "authentication",
    "headless-auth",
    "typescript",
    "security",
    "session-management",
    "token-rotation",
    "argon2",
    "zod",
    "framework-agnostic",
    "nextjs",
    "hono",
    "express",
    "prisma-adapter",
    "mongoose-adapter"
  ],
  "license": "MIT",
  "description": "A framework-agnostic modular auth engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapter": {
      "types": "./dist/adapter.d.ts",
      "import": "./dist/adapter.js",
      "require": "./dist/adapter.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "import": "./dist/providers.js",
      "require": "./dist/providers.cjs"
    },
    "./memoryAdapter": {
      "types": "./dist/memoryAdapter.d.ts",
      "import": "./dist/memoryAdapter.js",
      "require": "./dist/memoryAdapter.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node build.js"
  },
  "dependencies": {
    "arctic": "^3.7.0",
    "argon2": "^0.44.0",
    "jose": "^6.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}